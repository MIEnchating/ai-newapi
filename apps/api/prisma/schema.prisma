generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UpstreamType {
  NEWAPI
  SUB2API
}

enum AuthMode {
  API_KEY
  PASSWORD
  USER_TOKEN
  SESSION
  ADMIN_TOKEN
}

enum UpstreamStatus {
  OK
  LIMITED
  CHALLENGE_REQUIRED
  EXPIRED
  ERROR
  DISABLED
}

enum RateDirection {
  UP
  DOWN
  NEW
  REMOVED
  STABLE
}

enum AlertRuleType {
  RATE_INCREASE
  RATE_DECREASE
  BALANCE_LOW
  LATENCY_HIGH
  LATENCY_DISABLED
  SYNC_ERROR
  CHALLENGE_REQUIRED
  CREDENTIAL_EXPIRED
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

model Upstream {
  id                   String            @id @default(cuid())
  name                 String
  type                 UpstreamType
  baseUrl              String
  authMode             AuthMode
  groupName            String            @default("default")
  mainStationGroupName String?
  upstreamName         String?
  upstreamUserId       String?
  keyName              String?
  rechargeRatio        Decimal           @default(1) @db.Decimal(10, 2)
  priority             Int               @default(50)
  weight               Int               @default(0)
  status               UpstreamStatus    @default(LIMITED)
  balance              Decimal?          @db.Decimal(18, 6)
  balanceCurrency      String?
  concurrency          Int?
  latencyMs            Int?
  latencyCheckedAt     DateTime?
  latencyFailureCount  Int               @default(0)
  latencySuccessCount  Int               @default(0)
  latencyLastError     String?
  disabledByLatency    Boolean           @default(false)
  skipLatencyDisable   Boolean           @default(false)
  latencyDisabledAt    DateTime?
  latencyNextCheckAt   DateTime?
  credential           Credential?
  lastSyncAt           DateTime?
  lastError            String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  rateSnapshots        RateSnapshot[]
  rateChangeEvents     RateChangeEvent[]

  @@index([type])
  @@index([status])
}

model Credential {
  id               String   @id @default(cuid())
  upstreamId       String   @unique
  encryptedPayload String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  upstream         Upstream @relation(fields: [upstreamId], references: [id], onDelete: Cascade)
}

model RateSnapshot {
  id              String   @id @default(cuid())
  upstreamId      String
  provider        String
  model           String
  groupName       String?
  channelName     String?
  inputPrice      Decimal? @db.Decimal(18, 8)
  outputPrice     Decimal? @db.Decimal(18, 8)
  modelRatio      Decimal? @db.Decimal(18, 8)
  completionRatio Decimal? @db.Decimal(18, 8)
  currency        String?
  source          String
  rawHash         String?
  capturedAt      DateTime
  createdAt       DateTime @default(now())
  upstream        Upstream @relation(fields: [upstreamId], references: [id], onDelete: Cascade)

  @@index([upstreamId, provider, model, groupName, capturedAt])
  @@index([capturedAt])
}

model RateChangeEvent {
  id            String        @id @default(cuid())
  upstreamId    String
  provider      String
  model         String
  groupName     String?
  field         String
  direction     RateDirection
  oldValue      Decimal?      @db.Decimal(18, 8)
  newValue      Decimal?      @db.Decimal(18, 8)
  changePercent Decimal?      @db.Decimal(18, 6)
  createdAt     DateTime      @default(now())
  upstream      Upstream      @relation(fields: [upstreamId], references: [id], onDelete: Cascade)

  @@index([upstreamId, createdAt])
  @@index([direction])
}

model InspectionSetting {
  id                        String    @id @default("default")
  enabled                   Boolean   @default(true)
  intervalMs                Int       @default(900000)
  latencyTestEnabled        Boolean   @default(true)
  latencyIntervalMs         Int       @default(300000)
  latencyTimeoutMs          Int       @default(10000)
  latencyDisableThresholdMs Int       @default(8000)
  latencyFailureLimit       Int       @default(3)
  disabledRetestMs          Int       @default(1800000)
  cpaPreferred              Boolean   @default(false)
  inspectionConcurrency     Int       @default(3)
  balanceLowAction          String    @default("NONE")
  rateIncreaseAction        String    @default("NONE")
  ruleActionPriority        Int       @default(10)
  ruleActionWeight          Int       @default(0)
  lastRunAt                 DateTime?
  lastQueuedAt              DateTime?
  lastResult                String?
  lastError                 String?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
}

model AlertRule {
  id               String        @id @default(cuid())
  type             AlertRuleType @unique
  name             String
  enabled          Boolean       @default(true)
  severity         AlertSeverity @default(WARNING)
  thresholdPercent Decimal?      @db.Decimal(10, 4)
  thresholdMs      Int?
  thresholdAmount  Decimal?      @db.Decimal(18, 6)
  failureLimit     Int?
  cooldownMinutes  Int           @default(30)
  notificationMethods String      @default("")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model MainStation {
  id                  String    @id @default("relay-newapi-main")
  name                String    @default("主站")
  baseUrl             String    @default("")
  auth                String    @default("管理 Token")
  adminUserId         String    @default("")
  encryptedAdminToken String?
  lastSyncAt          DateTime?
  lastError           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model AdminUser {
  id                 String         @id @default(cuid())
  username           String         @unique
  passwordHash       String
  passwordSalt       String
  passwordIterations Int
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  sessions           AdminSession[]
}

model AdminSession {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
